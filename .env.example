# FocusBarber — exemplo de variáveis de ambiente.
# Copie para .env e ajuste. .env está gitignored (PRD §13.6).

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=dev-insecure-change-me-use-django-secret-key-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL (dev local + contêineres)
# DATABASE_URL define a conexão completa; DB_HOST/PORT são usados pelo
# entrypoint para aguardar o socket do banco antes de migrar.
DATABASE_URL=postgres://focusbarber:focusbarber@localhost:5432/focusbarber
DB_HOST=db
DB_PORT=5432
POSTGRES_DB=focusbarber
POSTGRES_USER=focusbarber
POSTGRES_PASSWORD=focusbarber